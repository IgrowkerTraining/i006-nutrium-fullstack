# Database Configuration
DB_HOST=localhost
DB_USER=postgres
DB_PASS=password
DB_NAME=nutriom_db
DB_PORT=5432

# JWT Configuration
# Change this to a strong random string in production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# AI Microservice (Python/FastAPI)
# En Docker: usar el nombre del servicio del compose (ej: http://nutrium-ai:8000/api/v1)
# En local:  http://localhost:8000/api/v1
AI_SERVICE_URL=http://nutrium-ai:8000/api/v1
